algoritmo "SomaAteTrinta"
var
   N, Soma: inteiro
inicio
      N <- 1
      Soma <- 0
      Enquanto (N <= 30) faça
               Escreval(N)

      Soma <- Soma + N
      N <- N + 1

      
fimenquanto
           Escreval("O valor total da soma dos números de 1 até 30 é: ", soma)

      
fimalgoritmo